--// Miner toggles (sorted by price desc)
local MineralsSection = Tab:NewSection("Минералы (галочки)")

local sorted = {}
for t, v in pairs(VALUES) do
	table.insert(sorted, {t=t, v=v})
end
table.sort(sorted, function(a,b) return a.v > b.v end)

for _, item in ipairs(sorted) do
	local t = item.t
	local price = item.v
	MineralsSection:NewToggle(t .. " (" .. tostring(price) .. ")", "Показывать " .. t, function(state)
		enabledMinerals[t] = state
		-- если выключили конкретный минерал — мгновенно спрячем все его метки
		if not state then
			for obj, info in pairs(tracked) do
				if info.type == t then
					hideForObj(obj)
				end
			end
		end
	end)
end
