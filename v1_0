--// CACHES / REGISTRY
-- tracked[obj] = { part = BasePart, type = string?, price = number?, locked = bool? }
local tracked = {}
local trackedCount = 0

-- onlyShown[obj] = true (объекты, у которых сейчас показан BillboardGui)
local onlyShown = {}

-- GUI pool: не Destroy/Create постоянно
local guiPool = {}      -- {BillboardGui,...}
local guiInUse = {}     -- [BillboardGui]=true
local guiByObj = {}     -- [Instance]=BillboardGui

-- connections for attribute updates
local connByObj = {}    -- [Instance] = {RBXScriptConnection,...}

-- root cache
local rootPart = nil

--// Helpers
local function getMainPart(obj)
	if obj:IsA("BasePart") then
		return obj
	end
	if obj:IsA("Model") then
		return obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
	end
	return nil
end

local function ensureRoot()
	local char = LocalPlayer.Character
	if not char then
		rootPart = nil
		return
	end
	rootPart = char:FindFirstChild("HumanoidRootPart")
end

local function teleportTo(targetCFrame)
	ensureRoot()
	if not rootPart then return end

	rootPart.AssemblyLinearVelocity = Vector3.zero
	rootPart.AssemblyAngularVelocity = Vector3.zero
	rootPart.CFrame = targetCFrame
end

LocalPlayer.CharacterAdded:Connect(function()
	task.defer(ensureRoot)
end)
ensureRoot()

--// GUI pool
local function makeBillboard()
	local billboard = Instance.new("BillboardGui")
	billboard.Name = "TextESP"
	billboard.Size = UDim2.new(0, 220, 0, 60)
	billboard.StudsOffset = Vector3.new(0, 3, 0)
	billboard.AlwaysOnTop = true
	billboard.Enabled = false

	local label = Instance.new("TextLabel")
	label.Name = "Label"
	label.Size = UDim2.new(1, 0, 1, 0)
	label.BackgroundTransparency = 1
	label.TextScaled = true
	label.Font = Enum.Font.SourceSansBold
	label.TextStrokeTransparency = 0
	label.TextColor3 = Color3.fromRGB(255, 255, 255)
	label.Text = ""
	label.Parent = billboard

	return billboard
end

local function acquireGui()
	local gui = table.remove(guiPool)
	if not gui then gui = makeBillboard() end
	guiInUse[gui] = true
	gui.Enabled = true
	return gui
end

local function releaseGui(gui)
	if not gui then return end
	gui.Enabled = false
	gui.Adornee = nil
	gui.Parent = nil
	guiInUse[gui] = nil
	table.insert(guiPool, gui)
end

local function hideForObj(obj)
	local gui = guiByObj[obj]
	if gui then
		guiByObj[obj] = nil
		releaseGui(gui)
	end
	onlyShown[obj] = nil
end

local function showForObj(obj, part, text)
	local gui = guiByObj[obj]
	if not gui then
		gui = acquireGui()
		guiByObj[obj] = gui
	end
	gui.Adornee = part
	gui.Parent = obj

	local label = gui:FindFirstChild("Label")
	if label then
		label.Text = text
	end

	onlyShown[obj] = true
end

local function formatEspText(infoType, infoPrice, dist)
	return string.format("%s\n%s\n%dm", infoType, tostring(infoPrice), math.floor(dist + 0.5))
end

--// Track/untrack
local function disconnectObj(obj)
	local list = connByObj[obj]
	if list then
		for _, c in ipairs(list) do
			pcall(function() c:Disconnect() end)
		end
	end
	connByObj[obj] = nil
end

local function untrack(obj)
	if tracked[obj] then
		tracked[obj] = nil
		trackedCount -= 1
	end
	hideForObj(obj)
	disconnectObj(obj)
end

local function updateCacheFor(obj)
	local info = tracked[obj]
	if not info then return end

	info.locked = obj:GetAttribute("Locked")
	info.type = obj:GetAttribute("Type")

	if info.type and VALUES[info.type] then
		info.price = VALUES[info.type]
	else
		info.price = nil
	end
end

local function shouldBeConsidered(info)
	-- мастер выключен => нет
	if not masterEnabled then return false end
	-- нет цены => не наш минерал
	if not info.price then return false end
	-- Locked должен быть false
	if info.locked ~= false then return false end
	-- галочка минерала
	if not enabledMinerals[info.type] then return false end
	-- должен быть part
	if not info.part or not info.part.Parent then return false end
	return true
end

local function watch(obj)
	if tracked[obj] then
		return
	end

	if not obj:IsA("Model") and not obj:IsA("BasePart") then
		return
	end

	local part = getMainPart(obj)
	if not part then return end

	tracked[obj] = { part = part, type = nil, price = nil, locked = nil }
	trackedCount += 1

	updateCacheFor(obj)

	connByObj[obj] = connByObj[obj] or {}

	table.insert(connByObj[obj], obj:GetAttributeChangedSignal("Locked"):Connect(function()
		updateCacheFor(obj)
	end))

	table.insert(connByObj[obj], obj:GetAttributeChangedSignal("Type"):Connect(function()
		updateCacheFor(obj)
	end))

	table.insert(connByObj[obj], obj.AncestryChanged:Connect(function(_, parent)
		if parent == nil then
			untrack(obj)
		end
	end))
end

local function scanWorkspaceOnce()
	local all = workspace:GetDescendants()
	for i, obj in ipairs(all) do
		watch(obj)
		if i % 400 == 0 then
			task.wait() -- не фризим запуск
		end
	end
end

-- запускаем скан в отдельной задаче, чтобы UI появился быстрее
task.spawn(scanWorkspaceOnce)
workspace.DescendantAdded:Connect(watch)

task.spawn(function()
	while true do
		task.wait(UPDATE_INTERVAL)

		if not rootPart or not rootPart.Parent then
			ensureRoot()
		end

		if not masterEnabled then
			for obj in pairs(onlyShown) do
				hideForObj(obj)
			end
			continue
		end

		local root = rootPart
		if not root then
			for obj in pairs(onlyShown) do
				hideForObj(obj)
			end
			continue
		end

		local rootPos = root.Position

		for obj, info in pairs(tracked) do
			if (not info.part) or (info.part and not info.part.Parent) then
				info.part = getMainPart(obj)
			end

			if shouldBeConsidered(info) then
				local dist = (rootPos - info.part.Position).Magnitude
				if dist <= maxDistance then
					showForObj(obj, info.part, formatEspText(info.type, info.price, dist))
				else
					hideForObj(obj)
				end
			else
				hideForObj(obj)
			end
		end
	end
end)

--// DISTANCE REFRESH LOOP (обновляет метры у уже показанных каждые ~250мс)
do
	local elapsed = 0
	RunService.Heartbeat:Connect(function(dt)
		elapsed += dt
		if elapsed < DISTANCE_REFRESH_INTERVAL then
			return
		end
		elapsed = 0

		if not masterEnabled then return end
		if not rootPart or not rootPart.Parent then
			ensureRoot()
		end

		local root = rootPart
		if not root then return end

		local rootPos = root.Position
		for obj in pairs(onlyShown) do
			local info = tracked[obj]
			local gui = guiByObj[obj]
			if info and info.part and info.part.Parent and gui then
				local label = gui:FindFirstChild("Label")
				if label then
					local dist = (rootPos - info.part.Position).Magnitude
					label.Text = formatEspText(info.type, info.price, dist)
				end
			end
		end
	end)
end

